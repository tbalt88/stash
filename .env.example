# ─────────────────────────────────────────────
# Stash — environment variable reference
# Copy to .env and fill in values for your environment.
# Variables marked [required] must be set for that feature to work.
# ─────────────────────────────────────────────

# ── Server ───────────────────────────────────
PORT=3456

# ── Database ─────────────────────────────────
# Used by docker-compose.prod.yml. Choose strong credentials.
POSTGRES_USER=stash
POSTGRES_PASSWORD=changeme
POSTGRES_DB=stash

# Full connection string used by direct backend runs (`./start.sh`).
# Docker Compose sets its own in-network DATABASE_URL for containers.
DATABASE_URL=postgresql://stash:stash@localhost:5432/stash

# Connection pool sizing. Increase DB_POOL_MAX for high-traffic deployments.
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── URLs & CORS ───────────────────────────────
# PUBLIC_URL is the frontend origin (used for invite links, CORS defaults).
# ⚠ PRODUCTION: set to your actual domain, e.g. https://app.yourcompany.com
PUBLIC_URL=http://localhost:3457
CORS_ORIGINS=http://localhost:3457,http://localhost:3456

# ── Admin Analytics ──────────────────────────
# Optional. Leave ADMIN_PASSWORD unset to disable backend admin endpoints.
# When set, both values must be at least 32 characters.
# ADMIN_PASSWORD=
# ADMIN_COOKIE_SECRET=

# ── Security audit ───────────────────────────
# HMAC key for redacted identifiers (emails, client IPs) in security audit
# events. Required when AUTH0_ENABLED=true; local dev uses a built-in dev key.
# AUDIT_HASH_KEY=

# ── Managed Auth0 ────────────────────────────
# Optional for self-hosting. Required for the managed product.
# AUTH0_ENABLED=true
# NEXT_PUBLIC_AUTH0_ENABLED=true
# AUTH0_DOMAIN=tenant.example.com
# AUTH0_AUDIENCE=https://api.yourcompany.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_SECRET=
# Must be an HTTPS origin without a path when managed Auth0 is enabled.
# APP_BASE_URL=https://app.yourcompany.com

# ── Live Collaboration ───────────────────────
# The frontend defaults to ws://localhost:3458 in local dev and /collab on
# deployed same-origin installs. Keep Caddy's /collab route when using the
# prebuilt self-host frontend image.

# Used by the collab sidecar to authorize users through FastAPI.
BACKEND_URL=http://localhost:3456

# ── Embeddings ──────────────────────────────────────────────────
# Provider: openai | huggingface | local | auto (default).
# "auto" detects from available keys: OPENAI_API_KEY → openai, HF_TOKEN → huggingface, else → local.
# With no keys set, Stash uses local sentence-transformers — no API key required.
# EMBEDDING_PROVIDER=auto

# Option 1: OpenAI (or any OpenAI-compatible API — Gemini, Cohere, Nomic, etc.)
# OPENAI_API_KEY=sk-proj-...
# EMBEDDING_API_KEY=sk-...                  # optional override for embedding-only key
# EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
# EMBEDDING_MODEL=text-embedding-3-small

# Option 2: Hugging Face Inference API (any HF Hub model)
# HF_TOKEN=hf_...
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5          # default

# Option 3: Local sentence-transformers (free, no API key, downloads model on first use)
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=all-MiniLM-L6-v2          # default

# Shared
# EMBEDDING_DIMS=384                        # vector dimensions (must match your DB schema)

# ── Linear ──────────────────────────────────
# Used by session ticket-label enrichment after Stash extracts a Linear issue
# identifier from a transcript.
# LINEAR_API_KEY=lin_api_...
# LINEAR_API_URL=https://api.linear.app/graphql

# ── File Storage (S3-compatible) ─────────────
# Stash supports any S3-compatible object store (AWS S3, Cloudflare R2, MinIO).
# Leave blank to disable file uploads.
# Required when managed Auth0 is enabled. S3_ENDPOINT must be an HTTPS origin.
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_BUCKET=stash
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_REGION=auto

# ── Integrations (OAuth token encryption) ────
# Fernet key used to encrypt OAuth tokens stored for GitHub/Google Drive/Notion
# integrations. Required when managed Auth0 is enabled. `./start.sh` and Docker
# Compose generate a durable key automatically when this is unset. If you manage
# secrets outside Compose, set a comma-separated keyring: the first key encrypts
# new tokens, and later keys decrypt tokens written before rotation.
#
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# INTEGRATIONS_ENCRYPTION_KEY=

# Granola connects through its MCP server over OAuth 2.0 (Dynamic Client
# Registration + PKCE) — no client id/secret to manage. Set the publicly
# reachable backend callback URL Granola redirects to after sign-in. The MCP
# endpoint defaults to the public server and rarely needs overriding.
# Managed Auth0 deployments require configured OAuth redirect URIs to be HTTPS
# callback URLs without path params, query strings, or fragments. Localhost
# examples are local development only.
# GRANOLA_OAUTH_REDIRECT_URI=https://your-backend/api/v1/integrations/granola/callback
# GRANOLA_MCP_URL=https://mcp.granola.ai/mcp

# Gmail uses Google OAuth with the read-only Gmail API scope. Use a Gmail OAuth
# client from a separate Google Cloud project from Drive if disconnect/revocation
# needs to be independent.
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_REDIRECT_URI=http://localhost:3456/api/v1/integrations/gmail/callback

# Jira (Atlassian 3LO OAuth 2.0). Create an OAuth 2.0 (3LO) app at
# https://developer.atlassian.com/console and add the Jira API scopes
# read:jira-work, read:jira-user, offline_access.
# JIRA_OAUTH_CLIENT_ID=
# JIRA_OAUTH_CLIENT_SECRET=
# JIRA_OAUTH_REDIRECT_URI=http://localhost:3456/api/v1/integrations/jira/callback

# Asana OAuth 2.0. Create an app at https://app.asana.com/0/my-apps and enable
# the granular read scopes projects:read, tasks:read, users:read, workspaces:read.
# ASANA_OAUTH_CLIENT_ID=
# ASANA_OAUTH_CLIENT_SECRET=
# ASANA_OAUTH_REDIRECT_URI=http://localhost:3456/api/v1/integrations/asana/callback

# ── Ask-the-Stash (optional LLM features) ─────
# When set, enables the chat-style "ask-the-stash" answer endpoint and automatic
# session summarization. Without it those features quietly stay disabled — the
# core product (sessions, pages, files, skills, search) works fine without an
# LLM key.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6        # quality tier (default)
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5    # fast tier (default)

# ── PPTX export (required for /api/v1/pages/{id}/export?format=pptx) ─────
# The HTML→PPTX exporter calls the aspose-pptx service in powerpoint-mcp/
# (deployed to Render). Set the public URL + matching bearer token here.
# Without these, the pptx and gslides exporters will fail with a runtime
# error pointing at this missing config.
# ASPOSE_PPTX_URL=https://stash-o5mq.onrender.com
# ASPOSE_PPTX_TOKEN=...
