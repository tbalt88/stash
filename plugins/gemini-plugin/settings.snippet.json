{
  "_comment": "Merge the `hooks` block below into ~/.gemini/settings.json or <project>/.gemini/settings.json. Replace ${PLUGIN_ROOT} with the absolute path to this plugin dir. Timeouts are in MILLISECONDS.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-session-start",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_session_start.py",
            "timeout": 5000,
            "description": "Record Stash session id"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-prompt",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_prompt.py",
            "timeout": 3000,
            "description": "Stream user prompt to Stash"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-tool-use",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_tool_use.py",
            "timeout": 5000,
            "description": "Stream tool use to Stash history"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-stop",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_stop.py",
            "timeout": 10000,
            "description": "Stream session end to Stash"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "stash-session-end",
            "command": "python3 ${PLUGIN_ROOT}/scripts/on_session_end.py",
            "timeout": 5000,
            "description": "Clear Stash session state"
          }
        ]
      }
    ]
  }
}
